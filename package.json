{
  "name": "robit-link-mover",
  "private": true,
  "version": "1.3.0",
  "type": "module",
  "scripts": {
    "vite:dev": "vite --host 127.0.0.1 --port 1420",
    "build:frontend": "vite build",
    "build:helper": "npm run build:helper:dev",
    "build:helper:dev": "cargo build --manifest-path src-tauri/Cargo.toml --target-dir src-tauri/target-codex --bin robit-helper",
